# Copy this file to .env at the repo root and fill in real values.
# `netlify dev` loads this automatically.

# Random long string used to encrypt stored Yahoo tokens and sign OAuth state.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Yahoo Developer App credentials — see README.md "Yahoo setup" section.
# Not needed until you're ready to connect Yahoo.
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
